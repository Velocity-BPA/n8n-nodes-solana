{
  "name": "@velocity-bpa/n8n-nodes-solana",
  "version": "1.0.0",
  "description": "n8n community node for Solana blockchain operations",
  "keywords": [
    "n8n-community-node-package",
    "solana",
    "blockchain",
    "crypto",
    "web3"
  ],
  "license": "bsl-catalog",
  "homepage": "https://n8n.io",
  "author": {
    "name": "Velocity BPA",
    "email": "info@velocitybpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/velocity-bpa/n8n-nodes-solana.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SolanaApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Solana/Solana.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^7.15.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@types/node": "^20.14.8",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "n8n-workflow": "*",
    "prettier": "^3.3.2",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "axios": "^1.7.2"
  }
}